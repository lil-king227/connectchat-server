<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="3dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_sent"
        android:maxWidth="260dp"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Deleted message placeholder -->
        <TextView
            android:id="@+id/tvDeleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚫 This message was deleted"
            android:textColor="@color/time_text"
            android:textSize="13sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/bubble_text_sent"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Time + tick row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/time_text"
                android:textSize="11sp" />

            <!-- Tick text: grey ✓ = sent, green ✓✓ = read -->
            <TextView
                android:id="@+id/tvTick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="✓"
                android:textColor="@color/time_text"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
